+              <span>{formatAverageCount(row.expectedCount)}</span>
+              <span>{row.totalValue ? <Money value={row.totalValue} /> : "Unpriced"}</span>
+            </div>
+          );
+        })}
+      </div>
+        </>
+      )}
+    </section>
+  );
