+          <span>Expected amount</span>
+          <span>Expected value</span>
+        </div>
+        {outputRows.map((row) => {
+          const detailItem = row.quote.item ?? { name: row.output.name };
+          const canOpenDetail = row.quote.item && typeof row.quote.item.id === "number";
+          return (
+            <div
